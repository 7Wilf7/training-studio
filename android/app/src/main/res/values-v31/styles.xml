<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Android 12+ shows a MANDATORY system splash (the SplashScreen API)
         before our window background. By default its backdrop is the theme's
         light window background, which read as a pale lavender card flashing
         before our cream splash. Pin it to the app's cream (#F2F1EC) and let
         the launcher icon (the dark mountain tile) serve as the splash icon,
         so the system splash reads as "cream + dark logo" — visually
         continuous with our own cream "logo + Training Studio" splash that
         follows. android:background keeps our drawable as the post-system
         window background. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">#F2F1EC</item>
        <item name="android:background">@drawable/splash</item>
    </style>

</resources>
