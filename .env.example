# Copy this file to .env.local and fill in your Supabase project values.
# Supabase Dashboard → Project Settings → API:
#   VITE_SUPABASE_URL      = the "Project URL" (https://<ref>.supabase.co, NO /rest/v1 suffix)
#   VITE_SUPABASE_ANON_KEY = the "Publishable key" (sb_publishable_...) — browser-safe, RLS-scoped
#
# NEVER put the Secret key (sb_secret_... / service_role) here — it bypasses RLS
# and is for server-side Edge Functions only.
#
# .env.local is gitignored (never committed) and does not sync between machines —
# each machine needs its own copy. Missing it = the app loads to a blank white page.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
